{
  "name": "audio-chunk-upload",
  "version": "1.0.0",
  "description": "MVP audio recording + chunk upload with retry/resume",
  "type": "module",
  "scripts": {
    "server": "tsx watch mock-server/src/server.ts",
    "server:start": "tsx mock-server/src/server.ts",
    "start": "npm run build && npm run server:start",
    "build": "tsx scripts/build.ts",
    "dev": "tsx scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "fake-indexeddb": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
